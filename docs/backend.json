
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["korjob", "korfarmo"] },
        "lastSeen": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isPremium": { "type": "boolean" },
        "premiumUntil": { "type": "string", "format": "date-time" },
        "isBlocked": { "type": "boolean" },
        "blockReason": { "type": "string" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "JobListing": {
      "title": "Job Listing",
      "description": "Details of a job posting",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "company": { "type": "string" },
        "city": { "type": "string" },
        "salary": { "type": "string" },
        "hours": { "type": "string" },
        "age": { "type": "string" },
        "phone": { "type": "string" },
        "gender": { "type": "string" },
        "desc": { "type": "string" },
        "postedBy": { "type": "string" },
        "postedEmail": { "type": "string" },
        "postedUid": { "type": "string" },
        "postedAt": { "type": "string" },
        "views": { "type": "number" },
        "active": { "type": "boolean" },
        "isPremium": { "type": "boolean" },
        "image": { "type": "string" }
      },
      "required": ["title", "company", "city", "postedUid", "active"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A single message in a conversation",
      "type": "object",
      "properties": {
        "sender": { "type": "string" },
        "text": { "type": "string" },
        "time": { "type": "string" },
        "read": { "type": "boolean" }
      },
      "required": ["sender", "text", "time"]
    },
    "PremiumRequest": {
      "title": "Premium Request",
      "description": "User request for premium status with receipt",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "userName": { "type": "string" },
        "receiptImage": { "type": "string" },
        "timestamp": { "type": "number" },
        "isPremium": { "type": "boolean" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/jobs/{jobId}": {
      "schema": "JobListing",
      "description": "All job postings"
    },
    "/chats/{chatId}": {
      "schema": "ChatMessage",
      "description": "Direct messages between users"
    },
    "/premiumRequests/{requestId}": {
      "schema": "PremiumRequest",
      "description": "Requests for premium account status"
    }
  }
}
